{
  "name": "greentic-plan-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "The Greentic plan store as a Cloudflare Worker: stores DSSE-signed update plans, serves them anonymously, never holds a signing key.",
  "scripts": {
